generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Availability {
  ONCE_A_MONTH
  TWICE_A_MONTH
  EVENTUAL
  REMOTE
}

model Volunteer {
  id              String        @id @default(uuid()) @db.Uuid
  nome            String
  idade           Int?
  email           String
  whatsApp        String?       @map("whatsapp")
  localidade      String?
  disponibilidade Availability
  motivacao       String?       @db.Text

  @@map("volunteers")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  /// Hash bcrypt da senha (nunca texto puro)
  password  String   @map("password_hash")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

/// Cache do feed (preenchido pelo job / rota de sync; o site só lê via GET /api/instagram-cache).
model InstagramPost {
  id        String   @id
  imageUrl  String   @map("image_url")
  permalink String
  caption   String?  @db.Text
  createdAt DateTime @map("created_at")

  @@map("instagram_posts")
}
