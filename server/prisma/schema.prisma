generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Availability {
  ONCE_A_MONTH
  TWICE_A_MONTH
  EVENTUAL
  REMOTE
}

model Volunteer {
  id              String        @id @default(uuid()) @db.Uuid
  nome            String
  idade           Int?
  email           String
  whatsApp        String?       @map("whatsapp")
  localidade      String?
  disponibilidade Availability
  motivacao       String?       @db.Text

  @@map("volunteers")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  /// Hash bcrypt da senha (nunca texto puro)
  password  String   @map("password_hash")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

/// Cache do feed (preenchido pelo job / rota de sync; o site só lê via GET /api/instagram-cache).
model InstagramPost {
  id        String   @id
  imageUrl  String   @map("image_url")
  permalink String
  caption   String?  @db.Text
  createdAt DateTime @map("created_at")

  @@map("instagram_posts")
}

/// Configuração única do painel (próximo encontro, local). `id` fixo `default`.
model DashboardSettings {
  id            String    @id @default("default")
  nextEventDate DateTime? @map("next_event_date")
  eventLocation String?   @map("event_location") @db.VarChar(500)
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("dashboard_settings")
}

/// Até 6 fotos manuais (storage + roleta por `createdAt`).
model ManualPost {
  id        String   @id @default(uuid()) @db.Uuid
  imageUrl  String   @map("image_url")
  imageKey  String   @map("image_key")
  permalink String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("manual_posts")
}
