# Copie para .env e ajuste usuário/senha/host se necessário
DATABASE_URL="postgresql://postgres:SUA_SENHA@localhost:5432/db_rangoderua?schema=public"

# Origens extras para CORS (separadas por vírgula). Em produção, o servidor já inclui
# https://rangoderua.org.br e https://www.rangoderua.org.br e aceita qualquer host *.vercel.app.
# Em desenvolvimento, se vazio, usa *.
# CORS_ORIGIN="http://localhost:5173,https://seuusuario.github.io"

# JWT (obrigatório para login admin). Gere uma chave forte, ex.: openssl rand -base64 32
JWT_SECRET="troque-por-uma-chave-longa-e-secreta"

# Conta de administrador: e-mail usado no login de /admin e no seed (npm run db:seed).
# Após mudar estes valores, rode de novo: npm run db:seed — o hash da senha é atualizado no banco.
ADMIN_EMAIL="gestao@rangoderua.org.br"
ADMIN_PASSWORD="TroquePorSenhaForte2026!"

# E-mail (Nodemailer) — notificação de novo voluntário para o chefe (587, STARTTLS via requireTLS no código)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
MAIL_FROM="Rango de Rua <seu-email@gmail.com>"
BOSS_EMAIL="seu-email@gmail.com"
