{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "src",
    "declaration": false,
    "noEmit": false
  },
  "include": ["src/**/*.ts"]
}
